---

---

<section
  class="max-w-7xl mx-auto px-4 md:px-8 py-32 w-full relative overflow-hidden"
  id="engine"
>
  <div
    class="absolute top-[10%] left-0 w-[500px] h-[500px] bg-primary/5 blur-[150px] rounded-full pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-[20%] right-0 w-[600px] h-[600px] bg-accent/5 blur-[150px] rounded-full pointer-events-none"
  >
  </div>

  <div class="text-center mb-32 fade-up relative z-10">
    <h2
      class="font-display text-5xl md:text-7xl font-bold uppercase tracking-tighter mb-6 glitch"
      data-text="Co się dzieje po Twojej stronie – nic. Co dzieje się po naszej"
    >
      Co się dzieje po Twojej stronie – nic. Co dzieje się po naszej
    </h2>
    <p class="text-slate-400 max-w-2xl mx-auto font-light text-lg">
      Tutaj widać dokładnie, jak NEXUS zamienia pustą bazę w listę firm gotowych
      do rozmowy. Bez Twojego udziału.
    </p>
  </div>

  <div class="relative max-w-5xl mx-auto z-10">
    <div
      class="hidden md:block absolute left-1/2 top-4 bottom-12 w-px bg-white/5 -translate-x-1/2 z-0"
      id="timeline-track"
    >
      <div
        id="timeline-fill"
        class="w-px bg-primary/30 absolute top-0 left-0 rounded-full timeline-draw"
      >
      </div>
    </div>

    <div class="space-y-24 md:space-y-40">
      <div
        class="flex flex-col md:flex-row items-center gap-8 md:gap-0 fade-up glass-card-fade relative"
      >
        <div
          class="hidden md:flex absolute left-1/2 -translate-x-1/2 size-10 glass rounded-full items-center justify-center border border-primary/40 text-primary text-sm font-bold z-20 bg-bg-dark neon-shadow-cyan"
        >
          01
        </div>
        <div
          class="md:w-1/2 md:pr-16 flex flex-col items-start md:items-end text-left md:text-right"
        >
          <span
            class="inline-block px-3 py-1 bg-primary/10 border border-primary/20 rounded-full text-[10px] text-primary font-mono uppercase tracking-widest mb-4"
            >Faza 1</span
          >
          <h3 class="font-display text-3xl font-bold uppercase mb-4 text-white">
            Szukamy odpowiednich firm
          </h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Zamiast losowej listy, NEXUS buduje bazę firm pasujących do profilu,
            który opisałeś w formularzu. Branża, specjalizacja, wielkość,
            stanowisko osoby decyzyjnej. Żadnych przypadkowych kontaktów.
          </p>
        </div>
        <div class="md:w-1/2 md:pl-16 w-full">
          <div
            class="glass p-6 rounded-2xl border-white/5 opacity-80 backdrop-blur-sm group hover:border-primary/30 transition-all duration-500"
          >
            <div class="flex gap-2 mb-4">
              <div class="size-2 rounded-full bg-red-500/50"></div>
              <div class="size-2 rounded-full bg-yellow-500/50"></div>
              <div class="size-2 rounded-full bg-green-500/50"></div>
            </div>
            <div class="font-mono text-xs text-slate-500 space-y-2">
              <div class="flex justify-between">
                <span class="text-slate-300">Scan.run("firmy B2B tech")</span>
                <span class="text-primary">[OK]</span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-300">Filter(duplikaty)</span>
                <span class="text-primary">[-42 wiersze]</span>
              </div>
              <div
                class="h-1 bg-slate-800 rounded-full mt-4 w-full overflow-hidden"
              >
                <div class="h-full bg-primary w-full animate-pulse"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="flex flex-col md:flex-row-reverse items-center gap-8 md:gap-0 fade-up glass-card-fade relative"
      >
        <div
          class="hidden md:flex absolute left-1/2 -translate-x-1/2 size-10 glass rounded-full items-center justify-center border border-primary/40 text-primary text-sm font-bold z-20 bg-bg-dark neon-shadow-cyan"
        >
          02
        </div>
        <div class="md:w-1/2 md:pl-16 flex flex-col items-start text-left">
          <span
            class="inline-block px-3 py-1 bg-primary/10 border border-primary/20 rounded-full text-[10px] text-primary font-mono uppercase tracking-widest mb-4"
            >Faza 2</span
          >
          <h3 class="font-display text-3xl font-bold uppercase mb-4 text-white">
            Czyta każdą firmę przed napisaniem
          </h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Zanim wyślemy cokolwiek, NEXUS sprawdza stronę firmy, jej
            aktualności i to, czym się zajmuje. Szuka konkretnego powodu, dla
            którego Twoja oferta ma sens właśnie dla nich.
          </p>
        </div>
        <div class="md:w-1/2 md:pr-16 w-full">
          <div
            class="glass p-6 rounded-2xl border-white/5 opacity-80 backdrop-blur-sm group hover:border-primary/30 transition-all duration-500"
          >
            <div class="font-mono text-xs text-slate-500 space-y-3">
              <div class="text-primary/70">Cel: target-pro.com</div>
              <div class="text-white/80">> Szukanie Osoby Decyzyjnej...</div>
              <div class="text-accent pl-4">Znaleziono: Jan Kowalski (CEO)</div>
              <div class="text-white/80">> Analiza Case Studies...</div>
              <div class="text-primary pl-4">
                Wyekstrahowano: "Wzrost konwersji o 35%"
              </div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="flex flex-col md:flex-row items-center gap-8 md:gap-0 fade-up glass-card-fade relative"
      >
        <div
          class="hidden md:flex absolute left-1/2 -translate-x-1/2 size-10 glass rounded-full items-center justify-center border border-primary/40 text-primary text-sm font-bold z-20 bg-bg-dark neon-shadow-cyan"
        >
          03
        </div>
        <div
          class="md:w-1/2 md:pr-16 flex flex-col items-start md:items-end text-left md:text-right"
        >
          <span
            class="inline-block px-3 py-1 bg-primary/10 border border-primary/20 rounded-full text-[10px] text-primary font-mono uppercase tracking-widest mb-4"
            >Faza 3</span
          >
          <h3 class="font-display text-3xl font-bold uppercase mb-4 text-white">
            Pisze wiadomość, która brzmi jak od człowieka
          </h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-6">
            Każda wiadomość nawiązuje do czegoś konkretnego z tej firmy. Nie
            mamy jednego szablonu – mamy tyle wersji, ile firm na liście.
            Właśnie dlatego ludzie odpowiadają.
          </p>
        </div>
        <div class="md:w-1/2 md:pl-16 w-full">
          <div
            class="glass p-6 rounded-2xl border-l-2 border-primary border-t-white/5 border-r-white/5 border-b-white/5 opacity-80 backdrop-blur-sm group transition-all duration-500"
          >
            <div
              class="font-serif italic text-sm text-slate-300 leading-relaxed"
            >
              "Cześć Jan, widziałem Wasze ostatnie wdrożenie – gratuluję wzrostu
              konwersji o 35%. Zauważyłem jednak, że Wasze zespoły SDR tracą
              mnóstwo czasu na manualny research..."
            </div>
            <div class="mt-4 flex items-center gap-2">
              <div
                class="size-4 animate-spin rounded-full border-2 border-primary border-t-transparent"
              >
              </div>
              <span class="font-mono text-[10px] text-primary uppercase"
                >Draft wygenerowany</span
              >
            </div>
          </div>
        </div>
      </div>

      <div
        class="relative z-20 w-full glass rounded-3xl p-8 md:p-12 border border-white/10 bg-slate-950/60 backdrop-blur-2xl my-24 fade-up glass-card-fade hover:border-primary/30 transition-colors duration-500 overflow-hidden"
      >
        <div class="text-center mb-10">
          <h4
            class="font-mono text-xs text-primary uppercase tracking-widest mb-2"
          >
            Twoja domena jest bezpieczna. Twoja reputacja też.
          </h4>
          <h3 class="font-display text-2xl font-bold uppercase text-white">
            Wiarygodność i bezpieczeństwo
          </h3>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center md:text-left divide-y md:divide-y-0 md:divide-x divide-white/10"
        >
          <div class="pt-6 md:pt-0 md:pl-0 md:pr-8">
            <span class="material-symbols-outlined text-primary text-3xl mb-4"
              >shield</span
            >
            <h5 class="font-bold text-white mb-2">
              Twoja główna skrzynka jest bezpieczna
            </h5>
            <p class="text-slate-500 text-xs text-balance">
              Masz trzy opcje: stworzona przez nas osobna domena sprzedażowa
              (zalecamy), Twoje konto Google lub Microsoft, albo własna skrzynka
              podłączona przez dane logowania – szyfrowana natychmiast przez
              Google KMS, niedostępna dla nikogo poza Tobą. Niezależnie od
              wyboru, Twoja codzienna firmowa poczta nie jest w żaden sposób
              zaangażowana.
            </p>
          </div>
          <div class="pt-6 md:pt-0 md:px-8">
            <span class="material-symbols-outlined text-primary text-3xl mb-4"
              >bolt</span
            >
            <h5 class="font-bold text-white mb-2">
              Każdy adres sprawdzamy przed wysyłką
            </h5>
            <p class="text-slate-500 text-xs text-balance">
              Usuwamy nieaktualne adresy i pułapki spamowe, zanim wyjdzie
              jakakolwiek wiadomość. Dzięki temu jesteśmy słyszalni – a nie
              trafiamy do niechcianych folderów.
            </p>
          </div>
          <div class="pt-6 md:pt-0 md:pl-8">
            <span class="material-symbols-outlined text-primary text-3xl mb-4"
              >schedule</span
            >
            <h5 class="font-bold text-white mb-2">
              Wysyłamy jak człowiek, nie jak robot
            </h5>
            <p class="text-slate-500 text-xs text-balance">
              Wiadomości wychodzą z losowymi odstępami czasowymi, w godzinach
              pracy, po jednej naraz. Filtry pocztowe nie widzą żadnej
              automatyzacji.
            </p>
          </div>
        </div>
      </div>

      <div
        class="text-center fade-up relative z-10 glass px-8 py-4 rounded-full border border-white/10 backdrop-blur-md inline-block mx-auto left-1/2 -translate-x-1/2"
      >
        <h4 class="font-display font-bold text-3xl uppercase text-white">
          Co jeśli ktoś nie odpisał od razu?
        </h4>
      </div>

      <div
        class="flex flex-col md:flex-row-reverse items-center gap-8 md:gap-0 fade-up relative"
      >
        <div
          class="hidden md:flex absolute left-1/2 -translate-x-1/2 size-8 glass rounded-full items-center justify-center border border-accent/40 text-accent text-xs font-bold z-20 bg-bg-dark"
        >
          D1
        </div>
        <div class="md:w-1/2 md:pl-16 flex flex-col items-start text-left">
          <h3 class="font-display text-2xl font-bold uppercase mb-2 text-white">
            Pierwsza wiadomość
          </h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            Konkretna, krótka, zaadresowana do tej jednej firmy. Bez wstępu, bez
            lania wody.
          </p>
        </div>
        <div class="md:w-1/2 md:pr-16 hidden md:block"></div>
      </div>

      <div
        class="flex flex-col md:flex-row items-center gap-8 md:gap-0 fade-up relative"
      >
        <div
          class="hidden md:flex absolute left-1/2 -translate-x-1/2 size-8 glass rounded-full items-center justify-center border border-accent/40 text-accent text-xs font-bold z-20 bg-bg-dark"
        >
          D4
        </div>
        <div
          class="md:w-1/2 md:pr-16 flex flex-col items-start md:items-end text-left md:text-right"
        >
          <h3 class="font-display text-2xl font-bold uppercase mb-2 text-white">
            Przypomnienie z wartością
          </h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            Jeśli nie było odpowiedzi – nie pytamy "czy widziałeś maila?".
            Dorzucamy coś konkretnego: dane, obserwację z branży, case study.
            Utrzymujemy pozycję eksperta, nie natręta.
          </p>
        </div>
        <div class="md:w-1/2 md:pl-16 hidden md:block"></div>
      </div>

      <div
        class="flex flex-col md:flex-row-reverse items-center gap-8 md:gap-0 fade-up relative"
      >
        <div
          class="hidden md:flex absolute left-1/2 -translate-x-1/2 size-8 glass rounded-full items-center justify-center border border-accent/40 text-accent text-xs font-bold z-20 bg-bg-dark"
        >
          D7
        </div>
        <div class="md:w-1/2 md:pl-16 flex flex-col items-start text-left">
          <h3 class="font-display text-2xl font-bold uppercase mb-2 text-white">
            Ostatnie zamknięcie
          </h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            Ostatnia wiadomość. Krótka, uprzejma, z propozycją konkretnego
            działania. Jeśli dalej brak odpowiedzi – kończymy i nie wracamy.
          </p>
        </div>
        <div class="md:w-1/2 md:pr-16 hidden md:block"></div>
      </div>

      <div class="mt-32 fade-up glass-card-fade relative z-10">
        <div class="flex flex-col items-center justify-center mb-12 relative">
          <div class="h-16 w-px mb-6 relative"></div>
          <div
            class="inline-flex items-center gap-2 px-6 py-2 bg-green-500/10 border border-green-500/50 rounded-full backdrop-blur-md"
          >
            <span class="material-symbols-outlined text-green-500 text-sm"
              >subdirectory_arrow_right</span
            >
            <span
              class="text-xs font-mono text-green-400 uppercase font-bold tracking-widest"
              >Wykryto Zainteresowanie — Sekwencja Zatrzymana</span
            >
          </div>
        </div>

        <div
          class="max-w-4xl mx-auto rounded-3xl p-px bg-linear-to-b from-green-500/50 to-green-900/10 hover:-translate-y-2 transition-transform duration-700"
        >
          <div
            class="w-full h-full bg-slate-950/60 backdrop-blur-2xl p-10 md:p-14 rounded-3xl relative overflow-hidden text-center md:text-left flex flex-col md:flex-row items-center gap-10"
          >
            <div class="absolute inset-0 bg-green-500/3 pointer-events-none">
            </div>

            <div
              class="size-24 rounded-full bg-green-500/10 border border-green-500/20 flex flex-col items-center justify-center shrink-0 shadow-[0_0_30px_rgba(34,197,94,0.2)]"
            >
              <span class="relative flex h-4 w-4 mb-2">
                <span
                  class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
                ></span>
                <span
                  class="relative inline-flex rounded-full h-4 w-4 bg-green-500 shadow-[0_0_10px_#22c55e]"
                ></span>
              </span>
              <span
                class="text-[8px] font-mono text-green-500 font-bold uppercase text-center leading-tight"
                >GOTOWY<br />DO ZAMKNIĘCIA</span
              >
            </div>

            <div class="flex-1">
              <h3
                class="font-display text-3xl md:text-4xl font-bold uppercase mb-4 text-white drop-shadow-lg"
              >
                Teraz wkraczasz Ty.
              </h3>
              <p
                class="text-slate-300 leading-relaxed mb-6 text-sm md:text-base"
              >
                Kiedy ktoś odpisuje, NEXUS natychmiast zatrzymuje dalszą wysyłkę
                i powiadamia Cię. Dostajesz gotowego leada, który wie czym się
                zajmujesz i chce porozmawiać. Twoja robota zaczyna się tutaj.
              </p>
              <a
                href="#pricing"
                class="inline-flex items-center gap-3 text-green-400 font-display font-bold uppercase text-sm hover:text-green-300 transition-colors group"
              >
                <span
                  class="border-b border-green-400/30 group-hover:border-green-400 transition-colors pb-0.5"
                  >Sprawdź dostępne miejsca</span
                >
                <span
                  class="material-symbols-outlined group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .timeline-draw {
    height: 0%;
    opacity: 0;
  }
  .timeline-draw.active {
    height: 100%;
    opacity: 1;
    transition:
      height 4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      opacity 0.8s ease;
  }
</style>

<script>
  function setupTimeline() {
    const track = document.getElementById(
      "timeline-track",
    ) as HTMLElement | null;
    const fill = document.getElementById("timeline-fill") as HTMLElement | null;

    if (!track || !fill) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            fill.classList.add("active");
            observer.disconnect(); // Only once
          }
        });
      },
      { threshold: 0.05 },
    );

    observer.observe(track);
  }

  document.addEventListener("DOMContentLoaded", setupTimeline);
  document.addEventListener("astro:page-load", setupTimeline);
</script>
