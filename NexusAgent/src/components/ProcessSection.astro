---

---

<section
  class="max-w-7xl mx-auto px-4 md:px-8 py-32 w-full relative overflow-hidden"
  id="onboarding"
>
  <!-- Ambient glows -->
  <div
    class="absolute top-[20%] right-0 w-[500px] h-[500px] bg-primary/5 blur-[150px] rounded-full pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-[10%] left-0 w-[600px] h-[600px] bg-accent/5 blur-[150px] rounded-full pointer-events-none"
  >
  </div>

  <!-- Header -->
  <div class="text-center mb-32 fade-up relative z-10">
    <h2
      class="font-display text-5xl md:text-7xl font-bold uppercase tracking-tighter mb-6 glitch"
      data-text="Od zakupu do pierwszego kontaktu"
    >
      Od zakupu do pierwszego kontaktu
    </h2>
    <p class="text-slate-400 max-w-2xl mx-auto font-light text-lg">
      Większość klientów jest zaskoczona tym jak mało jest do zrobienia po ich
      stronie. Poświęcasz nam 15 minut – reszta dzieje się bez Ciebie.
    </p>
  </div>

  <div class="relative max-w-4xl mx-auto z-10">
    <!-- Center timeline line for Desktop -->
    <div
      class="hidden md:block absolute left-[28px] top-4 bottom-12 w-px bg-white/5 z-0"
    >
      <div class="w-px bg-primary/30 absolute top-0 left-0 h-full rounded-full">
      </div>
    </div>

    <div class="space-y-16">
      <!-- Step 01 -->
      <div class="flex flex-col md:flex-row gap-8 fade-up relative">
        <div class="shrink-0 relative z-20">
          <div
            class="size-14 glass rounded-full flex items-center justify-center border border-primary/40 text-primary text-lg font-bold bg-bg-dark neon-shadow-cyan"
          >
            01
          </div>
        </div>
        <div
          class="glass p-8 rounded-2xl border-white/5 opacity-90 backdrop-blur-sm group hover:border-primary/30 transition-all duration-500 flex-1"
        >
          <div class="flex items-center gap-4 mb-4">
            <h3 class="font-display text-2xl font-bold uppercase text-white">
              Dostęp od razu
            </h3>
            <span
              class="px-3 py-1 bg-primary/10 border border-primary/20 rounded-full text-[10px] text-primary font-mono uppercase tracking-widest"
            >
              Natychmiast
            </span>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">
            Po zakupie dostajesz bezpieczny link do formularza startowego. Bez
            czekania, bez telefonu od konsultanta.
          </p>
        </div>
      </div>

      <!-- Step 02 -->
      <div class="flex flex-col md:flex-row gap-8 fade-up relative">
        <div class="shrink-0 relative z-20">
          <div
            class="size-14 glass rounded-full flex items-center justify-center border border-primary/40 text-primary text-lg font-bold bg-bg-dark neon-shadow-cyan"
          >
            02
          </div>
        </div>
        <div
          class="glass p-8 rounded-2xl border-white/5 opacity-90 backdrop-blur-sm group hover:border-primary/30 transition-all duration-500 flex-1"
        >
          <div class="flex items-center gap-4 mb-4">
            <h3 class="font-display text-2xl font-bold uppercase text-white">
              Opisujesz nam swojego klienta
            </h3>
            <span
              class="px-3 py-1 bg-primary/10 border border-primary/20 rounded-full text-[10px] text-primary font-mono uppercase tracking-widest"
            >
              Do 24h
            </span>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">
            Wypełniasz formularz: co sprzedajesz, do kogo, w jakim celu, jak
            powinna brzmieć komunikacja. Zajmuje to 10–15 minut. To jedyny
            moment, który wymaga Twojego czasu.
          </p>
        </div>
      </div>

      <!-- Step 03 -->
      <div class="flex flex-col md:flex-row gap-8 fade-up relative">
        <div class="shrink-0 relative z-20">
          <div
            class="size-14 glass rounded-full flex items-center justify-center border border-primary/40 text-primary text-lg font-bold bg-bg-dark neon-shadow-cyan"
          >
            03
          </div>
        </div>
        <div
          class="glass p-8 rounded-2xl border-white/5 opacity-90 backdrop-blur-sm group hover:border-primary/30 transition-all duration-500 flex-1"
        >
          <div class="flex items-center gap-4 mb-4">
            <h3 class="font-display text-2xl font-bold uppercase text-white">
              Budujemy listę i konfigurujemy wysyłkę
            </h3>
            <span
              class="px-3 py-1 bg-primary/10 border border-primary/20 rounded-full text-[10px] text-primary font-mono uppercase tracking-widest"
            >
              24-48h
            </span>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">
            Na podstawie Twojego formularza przygotowujemy bazę firm i ustawiamy
            wszystko technicznie. Domena, poczta, harmonogram – my to ogarniamy.
          </p>
        </div>
      </div>

      <!-- Step 04 -->
      <div class="flex flex-col md:flex-row gap-8 fade-up relative">
        <div class="shrink-0 relative z-20">
          <div
            class="size-14 glass rounded-full flex items-center justify-center border border-primary/40 text-primary text-lg font-bold bg-bg-dark neon-shadow-cyan"
          >
            04
          </div>
        </div>
        <div
          class="glass p-8 rounded-2xl border-white/5 opacity-90 backdrop-blur-sm group hover:border-primary/30 transition-all duration-500 flex-1"
        >
          <div class="flex items-center gap-4 mb-4">
            <h3 class="font-display text-2xl font-bold uppercase text-white">
              NEXUS zaczyna pisać
            </h3>
            <span
              class="px-3 py-1 bg-primary/10 border border-primary/20 rounded-full text-[10px] text-primary font-mono uppercase tracking-widest"
            >
              Od 48h
            </span>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">
            Pierwsze wiadomości wychodzą. Każda jest inna, każda nawiązuje do
            konkretnej firmy. Cały czas Cię nie potrzebujemy.
          </p>
        </div>
      </div>

      <!-- Step 05 -->
      <div class="flex flex-col md:flex-row gap-8 fade-up relative">
        <div class="shrink-0 relative z-20">
          <div
            class="size-14 glass rounded-full flex items-center justify-center border border-primary/40 text-primary text-lg font-bold bg-bg-dark neon-shadow-cyan"
          >
            05
          </div>
        </div>
        <div
          class="glass p-8 rounded-2xl border-white/5 opacity-90 backdrop-blur-sm group hover:border-primary/30 transition-all duration-500 flex-1"
        >
          <div class="flex items-center gap-4 mb-4">
            <h3 class="font-display text-2xl font-bold uppercase text-white">
              Ty odbierasz to, co ważne
            </h3>
            <span
              class="px-3 py-1 bg-primary/10 border border-primary/20 rounded-full text-[10px] text-primary font-mono uppercase tracking-widest"
            >
              Co 3 dni
            </span>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">
            Dostajesz raport z liczbami i powiadomienie o każdym
            zainteresowanym. Nie przeglądasz skrzynki w poszukiwaniu odpowiedzi
            – one same trafiają do Ciebie.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
