---
interface Props {
  data?: {
    navLinks?: { label: string; url: string }[];
    slotTrackerText?: string;
    ctaText?: string;
    ctaUrl?: string;
  };
  slots?: { totalSlots?: number; usedSlots?: number };
}

const { data, slots } = Astro.props;

const navLinks = data?.navLinks || [
  { label: "Problem", url: "/#pain" },
  { label: "Demo ataku", url: "/#demo" },
  { label: "Proces", url: "/#engine" },
  { label: "Cennik / ROI", url: "/#pricing" },
];

// Label z Payload (tylko tekst, bez liczb), np. "Dostępne sloty"
const slotLabel = data?.slotTrackerText || "Dostępne sloty (aktywni klienci)";

// Liczby pobrane z props (SSR) - bez podwójnego fetchowania
const totalSlots = slots?.totalSlots ?? 10;
const usedSlots = slots?.usedSlots ?? 0;
const availableSlots = Math.max(0, totalSlots - usedSlots);

const ctaText = data?.ctaText || "Uruchom NEXUS";
const ctaUrl = data?.ctaUrl || "#pricing";
---

<header
  class="sticky top-0 z-50 backdrop-blur-xl bg-slate-950/80 border-b border-white/5 transition-all duration-300"
>
  <div
    class="flex items-center justify-between px-4 md:px-8 py-3 md:py-4 max-w-7xl mx-auto w-full relative z-50"
  >
    <a href="/" class="flex items-center gap-3 group shrink-0">
      <img
        src="/logo.webp"
        alt="Nexus Agent"
        fetchpriority="high"
        decoding="async"
        class="h-10 md:h-12 lg:h-16 w-auto auto-glitch"
      />
    </a>

    <nav
      class="hidden lg:flex items-center gap-6 xl:gap-10 font-display text-[10px] xl:text-xs uppercase tracking-widest text-slate-400"
    >
      {
        navLinks.map((link) => (
          <a
            class="hover:text-primary transition-colors duration-300 whitespace-nowrap"
            href={link.url}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3 md:gap-4 shrink-0">
      <div
        class="hidden xl:flex items-center bg-slate-900/50 border border-slate-800 px-4 py-1.5 rounded-full mr-2 pulse-glow shrink-0"
      >
        <span class="size-2 bg-primary rounded-full animate-pulse mr-2"></span>
        <span
          id="header-slot-counter"
          class="text-[10px] font-mono uppercase tracking-tighter text-slate-400 whitespace-nowrap"
          data-label={slotLabel}
          >{slotLabel}: {usedSlots} z {totalSlots} miejsc</span
        >
      </div>
      <a
        href={ctaUrl}
        class="hidden sm:inline-block bg-primary text-slate-950 font-display font-bold text-[10px] sm:text-xs uppercase px-5 py-2.5 sm:px-6 sm:py-3 rounded-full hover:brightness-110 hover:scale-105 transition-all duration-300 neon-shadow-cyan whitespace-nowrap shrink-0"
      >
        {ctaText}
      </a>
      
      <!-- Hamburger Menu Button -->
      <button 
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 focus:outline-none ml-1 relative z-50 shrink-0"
        aria-label="Toggle menu"
      >
        <span class="w-6 h-0.5 bg-white mb-1.5 transition-all duration-300 origin-center" id="hamburger-line-1"></span>
        <span class="w-6 h-0.5 bg-white mb-1.5 transition-all duration-300 origin-center" id="hamburger-line-2"></span>
        <span class="w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="hamburger-line-3"></span>
      </button>
    </div>
  </div>

</header>

  <!-- Mobile Menu Overlay -->
  <div 
    id="mobile-menu" 
    class="fixed inset-0 bg-slate-950/95 backdrop-blur-2xl z-40 transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden flex flex-col items-center justify-start p-6 overflow-y-auto"
  >
    <div class="h-20 w-full shrink-0"></div> <!-- Spacer for header -->
    <nav class="flex flex-col items-center gap-4 font-display text-base md:text-lg uppercase tracking-widest text-white w-full max-w-[280px] md:max-w-sm pb-10">
      {
        navLinks.map((link) => (
          <a
            class="hover:text-primary transition-colors duration-300 mobile-link w-full text-center py-4 border-b border-white/5 whitespace-nowrap"
            href={link.url}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={ctaUrl}
        class="mt-6 w-full bg-primary text-slate-950 font-display font-bold text-xs md:text-sm uppercase px-6 py-4 rounded-full neon-shadow-cyan mobile-link flex items-center justify-center whitespace-nowrap shrink-0"
      >
        {ctaText}
      </a>
    </nav>
  </div>

<script>
  // Menu Mobile Logic
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerLine1 = document.getElementById('hamburger-line-1');
  const hamburgerLine2 = document.getElementById('hamburger-line-2');
  const hamburgerLine3 = document.getElementById('hamburger-line-3');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    if (isMenuOpen) {
      mobileMenu?.classList.remove('translate-x-full');
      hamburgerLine1?.classList.add('rotate-45', 'translate-y-2');
      hamburgerLine2?.classList.add('opacity-0');
      hamburgerLine3?.classList.add('-rotate-45', '-translate-y-2');
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu?.classList.add('translate-x-full');
      hamburgerLine1?.classList.remove('rotate-45', 'translate-y-2');
      hamburgerLine2?.classList.remove('opacity-0');
      hamburgerLine3?.classList.remove('-rotate-45', '-translate-y-2');
      document.body.style.overflow = '';
    }
  }

  mobileMenuBtn?.addEventListener('click', toggleMenu);
  
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (isMenuOpen) toggleMenu();
    });
  });

  // Dynamicznie aktualizuj licznik slotów w headerze z API (client-side)
  async function refreshHeaderSlots() {
    try {
      const res = await fetch("/api/slots");
      if (!res.ok) return;
      const data = await res.json();
      const el = document.getElementById("header-slot-counter");
      if (el && data.total !== undefined && data.used !== undefined) {
        // Używamy data-label zamiast split(":"), żeby uniknąć błędów gdy label sam zawiera dwukropek
        const label = el.getAttribute("data-label") || "Dostępne sloty";
        el.textContent = `${label}: ${data.used} z ${data.total} miejsc`;
      }
    } catch {
      /* silent fail */
    }
  }

  // Inicjalne odświeżenie po załadowaniu
  document.addEventListener("DOMContentLoaded", refreshHeaderSlots);
  // Odświeżanie co 60 sekund
  setInterval(refreshHeaderSlots, 60_000);
</script>
